{% extends 'front.html.twig' %}

{% block title %}AfkArt | {{ evenement.nom }}{% endblock %}

{% block content %}
<div style="max-width: 1000px; margin: 0 auto; padding: 2rem 1rem;">
    
    <div style="text-align: center; margin-bottom: 4rem;">
        <a href="{{ path('app_evenement_index') }}" style="text-decoration: none; color: var(--color-terracotta); font-weight: 500; display: inline-flex; align-items: center; gap: 0.5rem; margin-bottom: 1rem;">
            ← Retour aux événements
        </a>
        <h1 style="font-size: 3.5rem; color: var(--color-brown); line-height: 1.2;">
            {{ evenement.nom }}
        </h1>
        <div style="display: flex; justify-content: center; gap: 2rem; margin-top: 1.5rem; color: var(--color-brown-light);">
            <div style="display: flex; align-items: center; gap: 0.5rem;">
                <span style="font-size: 1.2rem;">📍</span> {{ evenement.lieu }}
            </div>
            <div style="display: flex; align-items: center; gap: 0.5rem;">
                <span style="font-size: 1.2rem;">👤</span> Artisan: <span style="font-weight: 600; color: var(--color-terracotta);">{{ evenement.artisan }}</span>
            </div>
        </div>
    </div>

    <div style="display: grid; grid-template-columns: 1.6fr 1fr; gap: 3rem; align-items: start;">
        
        {# Main Content Column #}
        <div style="display: flex; flex-direction: column; gap: 3rem;">
            <div style="background: white; padding: 3.5rem; border-radius: 2.5rem; box-shadow: 0 15px 50px rgba(0,0,0,0.02); position: relative;">
                <div style="position: absolute; top: -10px; left: 3rem; background: var(--color-terracotta); width: 60px; height: 4px; border-radius: 2px;"></div>
                <h3 style="font-size: 1.8rem; margin-bottom: 2rem; color: var(--color-brown); font-family: 'Cormorant Garamond', serif; font-weight: 600;">À propos de l'événement</h3>
                <div style="color: var(--color-brown-light); line-height: 2; font-size: 1.15rem; white-space: pre-wrap; letter-spacing: 0.01rem;">
                    {{ evenement.description|nl2br }}
                </div>
            </div>
        </div>

        {# Sidebar Column #}
        <div style="display: flex; flex-direction: column; gap: 2.5rem;">
            
            {# Professional Info Card #}
            <div style="background: #fdfbf9; padding: 2.5rem; border-radius: 2.5rem; border: 1px solid var(--color-cream-dark); box-shadow: 0 10px 30px rgba(0,0,0,0.02);">
                
                {# Calendar Section #}
                <div style="margin-bottom: 3rem;">
                    <h4 style="font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.15rem; color: var(--color-terracotta); margin-bottom: 1.5rem; font-weight: 700;">Calendrier</h4>
                    <div style="display: flex; flex-direction: column; gap: 1.5rem;">
                        <div style="display: flex; align-items: flex-start; gap: 1rem;">
                            <div style="background: white; padding: 0.8rem; border-radius: 12px; box-shadow: 0 4px 10px rgba(0,0,0,0.03);">🗓️</div>
                            <div>
                                <div style="font-size: 0.8rem; color: var(--color-brown-light); font-weight: 600;">DÉBUT</div>
                                <div style="font-size: 1.05rem; color: var(--color-brown); font-weight: 500;">
                                    {{ evenement.dateDebut|date('d F Y') }} <span style="color: var(--color-brown-light); font-size: 0.9rem;">à {{ evenement.dateDebut|date('H:i') }}</span>
                                </div>
                            </div>
                        </div>
                        <div style="display: flex; align-items: flex-start; gap: 1rem;">
                            <div style="background: white; padding: 0.8rem; border-radius: 12px; box-shadow: 0 4px 10px rgba(0,0,0,0.03);">🏁</div>
                            <div>
                                <div style="font-size: 0.8rem; color: var(--color-brown-light); font-weight: 600;">FIN</div>
                                <div style="font-size: 1.05rem; color: var(--color-brown); font-weight: 500;">
                                    {{ evenement.dateFin|date('d F Y') }} <span style="color: var(--color-brown-light); font-size: 0.9rem;">à {{ evenement.dateFin|date('H:i') }}</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div style="height: 1px; background: var(--color-cream-dark); margin: 2rem 0;"></div>

                {# Availability Section #}
                <div>
                    <h4 style="font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.15rem; color: var(--color-terracotta); margin-bottom: 1.5rem; font-weight: 700;">Disponibilité</h4>
                    
                    {% set res_count = evenement.reservations|length %}
                    {% set percentage = (res_count / evenement.capacite * 100)|round %}
                    
                    <div style="display: flex; justify-content: space-between; margin-bottom: 1rem; font-weight: 600; color: var(--color-brown);">
                        <span>Places réservées</span>
                        <span style="color: var(--color-terracotta);">{{ res_count }} / {{ evenement.capacite }}</span>
                    </div>
                    
                    <div style="width: 100%; height: 10px; background: white; border-radius: 5px; overflow: hidden; margin-bottom: 1rem; border: 1px solid var(--color-cream-dark);">
                        <div style="width: {{ percentage }}%; height: 100%; background: var(--color-terracotta); border-radius: 5px; transition: width 0.5s ease;"></div>
                    </div>

                    <div style="text-align: center; font-size: 0.95rem; color: var(--color-brown-light);">
                        Il reste <strong style="color: var(--color-brown);">{{ evenement.capacite - res_count }}</strong> places.
                    </div>
                </div>
            </div>

            {# Footer Actions #}
            <div style="display: flex; gap: 1rem; margin-top: 1rem; padding: 0 1rem;">
                <a href="{{ path('app_evenement_edit', {'id': evenement.id}) }}" class="btn" style="flex: 1; border-radius: 1.5rem; font-size: 0.9rem; padding: 0.8rem; background: #e8eee8; color: #5d7a5d; border: none; font-weight: 600; text-align: center; text-decoration: none;">
                    Modifier
                </a>
                <div style="flex: 1;">
                    {{ include('evenement/_delete_form.html.twig') }}
                </div>
            </div>

        </div>
    </div>

        </div>
    </div>
</div>
{% endblock %}
{% extends 'front.html.twig' %}

{% block title %}AfkArt | Événements{% endblock %}

{% block content %}
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2.5rem;">
        <div>
            <h1 style="font-size: 2.5rem; margin-bottom: 0.5rem; color: var(--color-brown);">Événements</h1>
            <p style="color: var(--color-brown-light); font-size: 1.1rem;">
                Découvrez nos ateliers, expositions et rencontres artistiques.
            </p>
        </div>

        {# BOUTON IDENTIQUE À CELUI DE "+ Nouvelle Réservation" #}
        {% if is_granted('ROLE_ARTISAN') or is_granted('ROLE_ADMIN') %}
            <a href="{{ path('app_evenement_new') }}" class="btn btn-primary">
                <span>+ Nouvel Événement</span>
            </a>
        {% endif %}
    </div>

    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 2rem; margin-top: 1rem;">
        {% for evenement in evenements %}
            <div style="
                background: white;
                border-radius: 2rem;
                overflow: hidden;
                box-shadow: 0 10px 30px rgba(0,0,0,0.03);
                border: 1px solid rgba(0,0,0,0.02);
                transition: transform 0.3s;"
                onmouseover="this.style.transform='translateY(-5px)';"
                onmouseout="this.style.transform='translateY(0)';">
                
                <div style="padding: 2rem;">
                    <div style="margin-bottom: 1.5rem;">
                        <div style="
                            color: var(--color-terracotta);
                            font-size: 0.75rem;
                            font-weight: 700;
                            text-transform: uppercase;
                            letter-spacing: 0.05rem;
                            margin-bottom: 0.25rem;">
                            {{ evenement.dateDebut ? evenement.dateDebut|date('d F Y') : 'Date à venir' }}
                        </div>
                        <h3 style="font-size: 1.4rem; color: var(--color-brown); margin: 0; line-height: 1.2;">
                            {{ evenement.nom }}
                        </h3>
                    </div>

                    <div style="display: flex; flex-direction: column; gap: 1rem; margin-bottom: 2rem;">
                        <div style="display: flex; align-items: center; gap: 0.75rem; color: var(--color-brown-light); font-size: 0.95rem;">
                            <span style="opacity: 0.8;">🕒</span>
                            <span>
                                {{ evenement.dateDebut ? evenement.dateDebut|date('H:i') : '' }}
                                {% if evenement.dateFin %}
                                    - {{ evenement.dateFin|date('H:i') }}
                                {% endif %}
                            </span>
                        </div>

                        <div style="display: flex; align-items: center; gap: 0.75rem; color: var(--color-brown-light); font-size: 0.95rem;">
                            <span style="opacity: 0.8;">📍</span>
                            <span>{{ evenement.lieu }}</span>
                        </div>

                        <div style="display: flex; align-items: center; gap: 0.75rem; color: var(--color-brown-light); font-size: 0.95rem;">
                            <span style="opacity: 0.8;">👥</span>
                            <span>Capacité : {{ evenement.capacite }} places</span>
                        </div>
                    </div>

                    <div style="display: flex; gap: 0.5rem; border-top: 1px solid var(--color-cream); padding-top: 1.5rem;">
                        <a href="{{ path('app_evenement_show', {'id': evenement.id}) }}" class="btn btn-primary" style="flex: 1; text-align: center; padding: 0.8rem;">
                            Voir Détails
                        </a>

                        {% if is_granted('ROLE_ADMIN') %}
                            <a href="{{ path('app_evenement_edit', {'id': evenement.id}) }}" class="btn btn-outline" style="padding: 0.8rem;">
                                ✏️
                            </a>
                        {% endif %}
                    </div>
                </div>
            </div>
        {% else %}
            <div style="grid-column: 1 / -1; text-align: center; padding: 5rem 2rem; background: white; border-radius: 2rem; color: var(--color-brown-light);">
                <div style="font-size: 3rem; margin-bottom: 1rem;">🎨</div>
                <h3 style="font-size: 1.5rem; margin-bottom: 0.5rem;">Aucun événement</h3>
                <p>Revenez bientôt pour découvrir nos prochaines activités.</p>
            </div>
        {% endfor %}
    </div>
{% endblock %}
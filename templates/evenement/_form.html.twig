        border-radius: 0.75rem;
        border: 1px solid #e5e7eb;
        background: #f9fafb;
        color: var(--color-brown);
        font-family: 'Outfit', sans-serif;
        transition: all 0.2s;
    }
    .form-control:focus {
        border-color: var(--color-terracotta);

{{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
    <div class="form-grid">
        <div class="form-group" style="grid-column: span 2;">
            {{ form_label(form.nom) }}
            {{ form_widget(form.nom, {'attr': {'class': 'form-control', 'placeholder': 'Ex: Atelier de Poterie Traditionnelle'}}) }}
            {{ form_errors(form.nom) }}
        </div>

        <div class="form-group" style="grid-column: span 2;">
            {{ form_label(form.artisan) }}
            {{ form_widget(form.artisan, {'attr': {'class': 'form-control', 'placeholder': 'Nom de l\'artisan responsable'}}) }}
            {{ form_errors(form.artisan) }}
        </div>

        <div class="form-group" style="grid-column: span 2;">
            {{ form_label(form.description) }}
            {{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': 5, 'placeholder': 'Partagez les détails passionnants de cet événement...'}}) }}
            {{ form_errors(form.description) }}
        </div>

        <div class="form-group">
            {{ form_label(form.dateDebut) }}
            {{ form_widget(form.dateDebut, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.dateDebut) }}
        </div>

        <div class="form-group">
            {{ form_label(form.dateFin) }}
            {{ form_widget(form.dateFin, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.dateFin) }}
        </div>

        <div class="form-group">
            {{ form_label(form.lieu) }}
            {{ form_widget(form.lieu, {'attr': {'class': 'form-control', 'placeholder': 'Ex: Galerie Centrale, Paris'}}) }}
            {{ form_errors(form.lieu) }}
        </div>

        <div class="form-group">
            {{ form_label(form.capacite) }}
            {{ form_widget(form.capacite, {'attr': {'class': 'form-control', 'placeholder': 'Nombre de places'}}) }}
            {{ form_errors(form.capacite) }}
        </div>
    </div>
   
    <div style="display: flex; gap: 1rem; margin-top: 3rem; justify-content: center;">
        <button class="btn btn-primary" style="padding: 0.8rem 2.5rem; font-size: 1.1rem; box-shadow: 0 4px 15px rgba(196, 112, 75, 0.3);" type="submit">
            {{ button_label|default('Confirmer l\'Événement') }}
        </button>
        <a href="{{ path('app_evenement_index') }}" class="btn btn-outline" style="padding: 0.8rem 2rem;">
            Annuler
        </a>
    </div>
{{ form_end(form) }}

<style>
    .form-grid {
        display: grid;

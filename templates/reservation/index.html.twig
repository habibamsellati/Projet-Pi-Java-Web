{% extends 'front.html.twig' %}

{% block title %}AfkArt | Mes Réservations{% endblock %}

{% block content %}
<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
    <div>
        <h1 style="font-size: 2.5rem; margin-bottom: 0.5rem;">Mes Réservations</h1>
        <p style="color: var(--color-brown-light);">
            {% if app.user %}
                Gérez vos réservations aux ateliers et événements.
            {% else %}
                <span style="display:inline-flex; align-items:center; gap:0.5rem; color:var(--color-terracotta); background:var(--color-cream); padding:0.2rem 0.6rem; border-radius:0.5rem; font-size:0.9rem;">
                    💡 Connectez-vous pour conserver l'historique de vos réservations.
                </span>
            {% endif %}
        </p>
    </div>
    <a href="{{ path('app_reservation_new') }}" class="btn btn-primary">
        <span>+ Nouvelle Réservation</span>
    </a>
</div>

<div style="display:grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 2rem; margin-top: 1rem;">
    {% for reservation in reservations %}
        <div style="background: white; border-radius: 2rem; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.03); border: 1px solid rgba(0,0,0,0.02); transition: transform 0.3s;" onmouseover="this.style.transform='translateY(-5px)';" onmouseout="this.style.transform='translateY(0)';">
            
            <div style="padding: 2rem;">
                <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1.5rem;">
                    <div>
                        <div style="color: var(--color-terracotta); font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05rem; margin-bottom: 0.25rem;">RÉSERVATION #{{ reservation.id }}</div>
                        <h3 style="font-size: 1.4rem; color: var(--color-brown); margin: 0; line-height: 1.2;">{{ reservation.evenement ? reservation.evenement.nom : 'Événement inconnu' }}</h3>
                    </div>
                    
                    {% set status_info = {
                        'confirme': {'bg': '#dcfce7', 'color': '#166534', 'label': 'Confirmé'},
                        'annule': {'bg': '#fee2e2', 'color': '#991b1b', 'label': 'Annulé'},
                        'en_attente': {'bg': 'var(--color-cream)', 'color': 'var(--color-terracotta)', 'label': 'En attente'}
                    } %}
                    {% set status = status_info[reservation.statut]|default(status_info.en_attente) %}
                    
                    <div style="display: flex; flex-direction: column; align-items: flex-end; gap: 0.5rem;">
                        <div style="background: {{ status.bg }}; color: {{ status.color }}; padding: 0.3rem 0.8rem; border-radius: 9999px; font-size: 0.75rem; font-weight: 700;">
                            {{ status.label }}
                        </div>
                        {% if reservation.statut == 'en_attente' and reservation.createdAt %}
                            {% set expiry = reservation.createdAt|date_modify("+3 hours") %}
                            {% set now = "now"|date("U") %}
                            {% set expiry_u = expiry|date("U") %}
                            {% set diff = expiry_u - now %}
                            
                            {% if diff > 0 %}
                                <div style="font-size: 0.65rem; color: #991b1b; background: #fff1f2; padding: 0.2rem 0.6rem; border-radius: 0.5rem; display: flex; align-items: center; gap: 0.3rem; border: 1px solid #fecdd3;">
                                    ⏱️ Expire dans {{ (diff // 3600) }}h {{ (diff % 3600 // 60) }}m
                                </div>
                            {% else %}
                                <div style="font-size: 0.65rem; color: #991b1b; background: #fff1f2; padding: 0.2rem 0.6rem; border-radius: 0.5rem;">
                                    ⚠️ Expiré (En attente d'annulation)
                                </div>
                            {% endif %}
                        {% endif %}
                    </div>
                </div>

                <div style="display: flex; flex-direction: column; gap: 1rem; margin-bottom: 2rem;">
                    <div style="display: flex; align-items: center; gap: 0.75rem; color: var(--color-brown-light); font-size: 0.95rem;">
                        <span style="opacity: 0.8;">📅</span>
                        <span>{{ reservation.dateReservation ? reservation.dateReservation|date('d F Y à H:i') : 'Date non définie' }}</span>
                    </div>
                    {% if reservation.evenement %}
                    <div style="display: flex; align-items: center; gap: 0.75rem; color: var(--color-brown-light); font-size: 0.95rem;">
                        <span style="opacity: 0.8;">📍</span>
                        <span>{{ reservation.evenement.lieu }}</span>
                    </div>
                    {% endif %}
                </div>

                <div style="display: flex; gap: 0.5rem; border-top: 1px solid var(--color-cream); padding-top: 1.5rem;">
                    <a href="{{ path('app_reservation_show', {'id': reservation.id}) }}" class="btn btn-outline" style="flex: 1; font-size: 0.8rem; padding: 0.6rem;">
                        Détails
                    </a>
                    {% if reservation.statut == 'en_attente' %}
                        {% if reservation.createdAt %}
                            {% set expiry = reservation.createdAt|date_modify("+3 hours") %}
                            {% if expiry|date("U") > "now"|date("U") %}
                                <a href="{{ path('app_reservation_edit', {'id': reservation.id}) }}" class="btn btn-secondary" style="flex: 1; font-size: 0.8rem; padding: 0.6rem;">
                                    Modifier
                                </a>
                            {% endif %}
                        {% endif %}
                        {# Si pas de createdAt ou expiré, on ne montre pas Modifier #}
                    {% else %}
                        <a href="{{ path('app_reservation_edit', {'id': reservation.id}) }}" class="btn btn-secondary" style="flex: 1; font-size: 0.8rem; padding: 0.6rem;">
                            Modifier
                        </a>
                    {% endif %}
                    <form method="post" action="{{ path('app_reservation_delete', {'id': reservation.id}) }}" onsubmit="return confirm('Supprimer cette réservation ?');" style="margin:0;">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ reservation.id) }}">
                        <button class="btn btn-outline" style="padding: 0.6rem; color: #991b1b; border-color: #fee2e2; background: #fff0f0;">
                            🗑️
                        </button>
                    </form>
                </div>
            </div>
        </div>
    {% else %}
        <div style="grid-column: 1 / -1; text-align: center; padding: 5rem 2rem; background: white; border-radius: 2rem; color: var(--color-brown-light);">
            <div style="font-size: 3rem; margin-bottom: 1rem;">📅</div>
            <h3 style="font-size: 1.5rem; margin-bottom: 0.5rem;">Aucune réservation</h3>
            <p>Vous n'avez pas encore réservé de place pour nos prochains événements.</p>
            <a href="{{ path('app_evenement_index') }}" class="btn btn-primary" style="margin-top: 1.5rem;">
                Explorer les événements
            </a>
        </div>
    {% endfor %}
</div>
{% endblock %}

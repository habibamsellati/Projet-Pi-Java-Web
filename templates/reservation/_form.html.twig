{% if reservation.id and reservation.createdAt %}
    {% set expiry = reservation.createdAt|date_modify("+3 hours") %}
    {% set now = "now"|date("U") %}
    {% set expiry_u = expiry|date("U") %}
    {% set diff = expiry_u - now %}

    <div style="margin-bottom: 2.5rem; padding: 1.5rem; border-radius: 1rem; background: {% if diff > 0 %}#fefce8{% else %}#fff1f2{% endif %}; border: 1px solid {% if diff > 0 %}#fef08a{% else %}#fecdd3{% endif %};">
        <h5 style="margin: 0 0 0.5rem 0; color: {% if diff > 0 %}#854d0e{% else %}#991b1b{% endif %}; display: flex; align-items: center; gap: 0.5rem;">
            {% if diff > 0 %}⏱️ Délai de confirmation{% else %}⚠️ Délai expiré{% endif %}
        </h5>
        <p style="margin: 0; font-size: 0.9rem; color: var(--color-brown-light);">
            {% if diff > 0 %}
                Vous avez jusqu'au <strong>{{ expiry|date('H:i:s') }}</strong> pour confirmer ou modifier cette réservation. 
                Temps restant : <strong>{{ (diff // 3600) }}h {{ (diff % 3600 // 60) }}m</strong>.
            {% else %}
                Le délai de 3 heures est dépassé. Toute modification vers le statut "Confirmé" sera rejetée.
                {% if reservation.statut == 'annule' %}
                    <br><span style="color: #991b1b; font-weight: 600;">Cette réservation a été annulée suite au dépassement du délai.</span>
                {% endif %}
            {% endif %}
        </p>
    </div>
{% endif %}

{{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

    <div class="form-grid" style="grid-template-columns: 1fr; gap: 2rem;">
        <div class="form-group">
            {{ form_label(form.evenement) }}
            {{ form_widget(form.evenement, {'attr': {'class': 'form-control', 'style': 'height: 3.5rem;'}}) }}
            {{ form_errors(form.evenement) }}
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
            <div class="form-group">
                {{ form_label(form.dateReservation) }}
                {{ form_widget(form.dateReservation, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.dateReservation) }}
            </div>

            <div class="form-group">
                {{ form_label(form.statut) }}
                {{ form_widget(form.statut, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.statut) }}
            </div>
        </div>
    </div>

    <div style="display: flex; gap: 1rem; margin-top: 3.5rem; justify-content: center;">
        <button type="submit" class="btn btn-primary" style="padding: 0.8rem 2.5rem; font-size: 1.1rem; box-shadow: 0 4px 15px rgba(196, 112, 75, 0.3);">
            {{ button_label|default('Enregistrer ma réservation') }}
        </button>
        <a href="{{ path('app_reservation_index') }}" class="btn btn-outline" style="padding: 0.8rem 2rem;">
            Annuler
        </a>
    </div>

{{ form_end(form) }}


<style>
    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
    }

    @media (max-width: 768px) {
        .form-grid {
            grid-template-columns: 1fr;
        }
    }

    .form-group label {
        display: block;
        margin-bottom: 0.5rem;
        font-weight: 600;
        color: var(--color-brown);
    }

    .form-control {
        width: 100%;
        padding: 0.75rem 1rem;
        border-radius: 0.75rem;
        border: 1px solid #e5e7eb;
        background: #f9fafb;
        color: var(--color-brown);
        font-family: 'Outfit', sans-serif;
        transition: all 0.2s ease;
    }

    .form-control:focus {
        border-color: var(--color-terracotta);
        background: white;
        box-shadow: 0 0 0 4px rgba(196, 112, 75, 0.12);
        outline: none;
    }

    .form-errors {
        color: #dc2626;
        font-size: 0.875rem;
        margin-top: 0.25rem;
    }
</style>
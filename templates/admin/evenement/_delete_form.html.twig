<form method="post" action="{{ path('admin_evenement_delete', {'id': evenement.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet élément ?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ evenement.id) }}">
    <button class="btn" style="background: #e63946; color: white; padding: 8px 12px; border: none; border-radius: 4px; cursor: pointer;">Supprimer</button>
</form>

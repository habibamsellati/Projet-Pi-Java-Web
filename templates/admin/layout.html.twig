{% extends 'base.html.twig' %}

{% block title %}AfkArt | Admin{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('Assets/css/back.css') }}">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
{% endblock %}

{% block body %}
<div class="admin-container">

    <!-- ================= SIDEBAR ================= -->
    {{ include('admin/_sidebar.html.twig') }}

    <!-- ================= MAIN CONTENT ================= -->
    <main class="main-content">

        <!-- HEADER -->
        <header class="header">
            <div class="header-left">
                {% block header_title %}
                <h1>Dashboard</h1>
                <p class="header-subtitle">Bienvenue, Administrateur</p>
                {% endblock %}
            </div>
            <div class="header-right">
                <div class="search-box">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="11" cy="11" r="8"/>
                        <path d="M21 21l-4.35-4.35"/>
                    </svg>
                    <input type="text" placeholder="Rechercher...">
                </div>
                <!-- Notifications and Profile -->
                <button class="btn-icon notification">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
                        <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
                    </svg>
                    <span class="notification-dot"></span>
                </button>
                <div class="user-profile">
                    <div class="avatar">AD</div>
                    <div class="user-info">
                        <span class="user-name">Admin</span>
                        <span class="user-role">Super Admin</span>
                    </div>
                </div>
            </div>
        </header>

        <!-- PAGE CONTENT -->
        {% block admin_content %}{% endblock %}

    </main>
</div>
{% endblock %}

{% block javascripts %}
<script>
    // Sidebar navigation active state
    document.querySelectorAll('.nav-item a').forEach(link => {
        // Simple active state check based on URL, can be enhanced
        if (link.href === window.location.href) {
             document.querySelectorAll('.nav-item').forEach(item => item.classList.remove('active'));
             link.parentElement.classList.add('active');
        }
    });

    // Close dropdowns when clicking outside
    window.onclick = function(event) {
        if (!event.target.matches('.btn-secondary')) {
            var dropdowns = document.getElementsByClassName("dropdown-content");
            for (var i = 0; i < dropdowns.length; i++) {
                var openDropdown = dropdowns[i];
                if (openDropdown.style.display === 'block') {
                    openDropdown.style.display = 'none';
                }
            }
        } else {
             // Toggle logic moved here to handle button click safely
             var dropdown = event.target.nextElementSibling;
             if(dropdown && dropdown.classList.contains('dropdown-content')){
                dropdown.style.display = dropdown.style.display === 'block' ? 'none' : 'block';
             }
        }
    }
</script>
{% endblock %}
